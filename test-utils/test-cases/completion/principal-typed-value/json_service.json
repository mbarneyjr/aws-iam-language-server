---
includes:
  - "lambda.amazonaws.com"
  - "s3.amazonaws.com"
excludes:
  - "*"
  - "arn:${Partition}:iam::${Account}:root"
---
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "*",
      "Principal": {
        "Service": ["$0"]
      }
    }
  ]
}
