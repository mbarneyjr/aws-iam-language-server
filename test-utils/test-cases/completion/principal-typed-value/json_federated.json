---
includes:
  - "cognito-identity.amazonaws.com"
  - "accounts.google.com"
  - "arn:${Partition}:iam::${Account}:saml-provider/${SamlProviderName}"
excludes:
  - "lambda.amazonaws.com"
  - "*"
---
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "*",
      "Principal": {
        "Federated": ["$0"]
      }
    }
  ]
}
