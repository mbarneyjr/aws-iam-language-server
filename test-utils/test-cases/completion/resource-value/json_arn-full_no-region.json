---
includes:
  - "arn:aws:s3::123456789012:accesspoint/${AccessPointAlias}"
excludes:
  - "arn:aws:s3:::${BucketName}"
  - "arn:aws:s3:::${BucketName}/${ObjectName}"
---
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": [
        "arn:aws:s3::123456789012:$0
      ]
    }
  ]
}
