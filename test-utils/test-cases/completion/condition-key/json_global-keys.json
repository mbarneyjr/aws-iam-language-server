---
includes:
  - aws:PrincipalArn
  - aws:SourceIp
  - sts:ExternalId
  - sts:RoleSessionName
excludes:
  - s3:ResourceAccount
---
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["sts:AssumeRole"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "$0
        }
      }
    }
  ]
}
